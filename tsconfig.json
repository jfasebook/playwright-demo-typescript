{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    
    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    
    /* Module Interop */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "#framework/*": ["framework/*.ts"],
      "#support/*": ["support/*.ts"],
      "#tests/*": ["tests/*.ts"]
    },
    
    /* Output */
    "outDir": "dist",
    "sourceMap": true,
    
    /* Types */
    "types": ["node"]
  },
  "include": [
    "framework/**/*.ts",
    "support/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}
